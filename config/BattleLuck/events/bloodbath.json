        "spawn.boss",
        "npc.spawn",
        "team.swap",
        "shrink.zone",
        "event.finalize"
      ]
    },
    "examples": [
      {
        "request": "Start three enemies and announce the wave",
        "actions": [
          {
            "action": "announce",
            "params": {
              "text": "A new Bloodbath wave has begun."
            }
          },
          {
            "action": "spawn.wave",
            "params": {
              "waveId": "1",
              "count": "3"
            }
          }
        ]
      },
      {
        "request": "Make the arena harder without ending the event",
        "actions": [
          {
            "action": "shrink.zone",
            "params": {
              "targetRadius": "70",
              "durationSeconds": "60"
            }
          },
          {
            "action": "spawn.wave",
            "params": {
              "waveId": "3",
              "count": "5"
            }
          }
        ]
      },
      {
        "request": "Finish Bloodbath safely",
        "actions": [
          {
            "action": "announce",
            "params": {
              "text": "Bloodbath is ending. Restoring participants."
            }
          },
          {
            "action": "event.finalize",
            "params": {}
          }
        ]
      }
    ]
  },
