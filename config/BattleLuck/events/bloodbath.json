      "blockedActions": [
        "entity.destroy",
        "inventory.clear_all",
        "mode.end",
        "snapshot.restore",
        "snapshot.clear",
        "tech.apply",
        "progression.unlock.all_vbloods",
        "progression.unlock.all_research",
        "progression.unlock_gear",
        "progression.set_tier",
